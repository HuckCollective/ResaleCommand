---
// StoreHeaderCart.astro
// This runs dynamically on the server for each unique user session.
// Server Islands fetch this in a separate client request.
const { tenantId } = Astro.props;

// Read user session cookies safely here
const cartSession = Astro.cookies.get("store_cart_session");
const cartCount = cartSession ? 2 : 0; // Simple mock for demonstration
---
<div class="flex items-center gap-3">
  <!-- Cart Button -->
  <a href="/cart" class="btn btn-ghost btn-circle relative hover:bg-base-content/10 transition-colors">
    <div class="indicator">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      {cartCount > 0 && (
        <span class="badge badge-secondary badge-xs indicator-item animate-bounce">
          {cartCount}
        </span>
      )}
    </div>
  </a>

  <!-- User Account Dropdown -->
  <div class="dropdown dropdown-end">
    <label tabindex="0" class="btn btn-ghost btn-circle avatar online placeholder hover:bg-base-content/10 transition-colors">
      <div class="bg-neutral text-neutral-content rounded-full w-10">
        <span class="text-xs">U</span>
      </div>
    </label>
    <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-100 border border-base-content/5 rounded-box w-52">
      <li class="menu-title px-4 py-2 text-xs font-semibold uppercase opacity-50">
        Tenant: {tenantId}
      </li>
      <li><a class="hover:bg-primary/10 hover:text-primary transition-colors">My Profile</a></li>
      <li><a class="hover:bg-primary/10 hover:text-primary transition-colors">Order History</a></li>
      <li><a class="hover:bg-error/10 hover:text-error transition-colors mt-1">Sign Out</a></li>
    </ul>
  </div>
</div>
