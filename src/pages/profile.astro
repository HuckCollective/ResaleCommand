---
import Layout from '../layouts/Layout.astro';
import ProfileView from '../components/profile/ProfileView.vue';
---

<Layout title="Profile Settings - Resale Command">
  <div class="container mx-auto p-4 max-w-4xl space-y-8">
    
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-bold">Profile Settings</h1>
      <p class="text-gray-500">Manage your personal account settings and security.</p>
    </div>

    <!-- Client-side Profile Settings -->
    <ProfileView client:load />

  </div>
</Layout>
